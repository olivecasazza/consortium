{
  "name": "consortium",
  "version": "0.1.0",
  "description": "A Rust rewrite of ClusterShell with Python bindings",
  "main": "index.js",
  "scripts": {
    "commitlint": "commitlint --from HEAD~1 --to HEAD --exit-code",
    "commitlint:fix": "commitlint --from HEAD~1 --to HEAD --edit",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "clustershell",
    "cluster",
    "distributed",
    "parallel",
    "rust",
    "python"
  ],
  "author": "Stephane Thiell",
  "license": "LGPL-2.1-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/olivecasazza/consortium"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/github": "^11.0.0",
    "semantic-release": "^24.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "chore",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test",
          "build",
          "ops",
          "hotfix"
        ]
      ],
      "header-max-length": [
        2,
        "always",
        100
      ]
    }
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/github",
        {
          "assets": [
            "target/**/*.tar.gz",
            "target/**/*.zip"
          ],
          "releasedLabels": [
            "Status: Released"
          ]
        }
      ]
    ],
    "branches": [
      "main",
      "master"
    ]
  }
}
