FROM nixos/nix:latest

# Enable flakes and configure nix for builder use
RUN mkdir -p /etc/nix && \
    echo "experimental-features = nix-command flakes" >> /etc/nix/nix.conf && \
    echo "sandbox = false" >> /etc/nix/nix.conf && \
    echo "trusted-users = root" >> /etc/nix/nix.conf && \
    echo "accept-flake-config = true" >> /etc/nix/nix.conf

# Install openssh
RUN nix-env -iA nixpkgs.openssh nixpkgs.gnused

# Create sshd privilege separation user and unlock root account
RUN mkdir -p /etc/ssh /root/.ssh /run /var/empty && \
    chmod 700 /root/.ssh && \
    echo "sshd:x:74:74:sshd privsep:/var/empty:/bin/false" >> /etc/passwd && \
    echo "sshd:x:74:" >> /etc/group && \
    sed -i 's/^root:!/root:*/' /etc/shadow && \
    cat > /etc/ssh/sshd_config << 'SSHD'
Port 22
PermitRootLogin prohibit-password
PasswordAuthentication no
PubkeyAuthentication yes
StrictModes no
SSHD
RUN ssh-keygen -A

# Create a minimal flake for testing builds
RUN mkdir -p /test-flake && \
    cat > /test-flake/flake.nix << 'FLAKE'
{
  description = "Test flake for consortium integration tests";
  inputs.nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";
  outputs = { nixpkgs, ... }: let
    pkgs = nixpkgs.legacyPackages.x86_64-linux;
  in {
    packages.x86_64-linux.hello = pkgs.hello;
    packages.x86_64-linux.test-derivation = pkgs.writeText "test-output" "built-by-consortium";
  };
}
FLAKE

EXPOSE 22

# Use -D (foreground) -e (log to stderr) -o to disable privilege separation
# Wrapper that sets PATH for nix binaries before starting sshd
RUN cat > /start-sshd.sh << 'EOF'
#!/bin/bash
export PATH="/root/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"
# Write environment for SSH sessions
echo "PATH=$PATH" > /etc/environment
echo "NIX_PATH=nixpkgs=flake:nixpkgs" >> /etc/environment
# Set PATH in sshd config so SSH sessions inherit it
echo "SetEnv PATH=$PATH" >> /etc/ssh/sshd_config
exec /root/.nix-profile/bin/sshd -D -e -f /etc/ssh/sshd_config
EOF
RUN chmod +x /start-sshd.sh

CMD ["/root/.nix-profile/bin/bash", "/start-sshd.sh"]
