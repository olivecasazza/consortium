# Gas City
.gc/
.beads/*
!.beads/config.yaml
!.beads/metadata.json
hooks/
.runtime/

# Nix-managed (mkCity in nixlab/homes/olive@seir/modules/gc-cities) —
# regenerated by home-manager activation; do not hand-edit. mkCity owns
# city.toml, pack.toml, and the prompt/agent.toml of every persona it
# declares. Persona-owned data files (atlas.toml, ledger.toml,
# diagrams/, scripts/, etc.) stay tracked here.
/city.toml
/pack.toml
/agents/mayor/
/agents/worker/
/agents/architect/prompt.template.md
/agents/architect/agent.toml
/agents/accountant/prompt.template.md
/agents/accountant/agent.toml

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Accountant runtime state — auto-generated by patrol.sh / notify.sh.
# Refreshed every 6h; not portable across machines.
agents/accountant/usage-snapshot.toml
agents/accountant/openrouter-models.json
agents/accountant/openrouter-key.json
agents/accountant/litellm-spend.json
agents/accountant/litellm-global-spend.json
agents/accountant/litellm-keys-spend.json
agents/accountant/receipts.tsv
agents/accountant/abandon-counts.tsv
agents/accountant/patrol.log

# D2 render artifacts — keep .d2 source, drop the SVG/PNG outputs.
agents/architect/diagrams/*.svg
agents/architect/diagrams/*.png

# Per-tool runtime state inside the city dir.
.claude/
.opencode/

# Local secrets file (never commit).
.env
