# gascity city config — consortium autoresearch swarm.
#
# This file describes the intended gascity setup for unattended overnight
# runs. The canonical driver right now is autoresearch/scripts/run-loop.sh
# (pure bash, no gascity dependency). When gascity is installed and the
# OpenAI-compat backend story is verified, this config becomes live via
# `gc start`.

[workspace]
provider = "claude"  # gascity default; we override the backend env vars
                     # so the underlying CLI talks to LiteLLM.

# A single rig: this fork.
[[rigs]]
name = "consortium-autoresearch"

# Two formulas — the work the city repeats.
#
# drain-queue: pop one task and process it end-to-end. Run continuously
#              up to <max-tasks> per night.
[[formulas]]
name = "drain-queue"
exec = "bash autoresearch/scripts/run-once.sh"
when = "queue-pending-nonempty"   # gascity should not fire when there's
                                  # nothing to do; falls back to interval
                                  # if this predicate isn't supported.
parallelism = 2                   # two agents at once. Bump after smoke
                                  # tests; capped by GPU contention.
timeout = "35m"                   # hard cap per task (program.md says 30m
                                  # for the agent itself, +5m for score).

# refill-queue: top up the queue from upstream commits and any new TODOs
#               introduced since the last seed.
[[formulas]]
name = "refill-queue"
exec = """bash -c '
    bash autoresearch/scripts/seed-queue.sh
    bash autoresearch/scripts/upstream-diff.sh --limit 5
'"""
schedule = "@hourly"
parallelism = 1

# Health patrol: kill agents whose worktrees are >1h old without a
# heartbeat. Implementation lives in run-once.sh's timeout(1) wrapper for
# now — this entry is a placeholder for the gascity-native version.
# [[health]]
# name = "stale-agents"
# rule = "worktree-age>1h && no-recent-commit"
# action = "kill+abandon"

# Backend env. gascity passes these through to spawned processes; the
# coding-agent CLI (opencode) reads them as OpenAI-compatible config.
# Set the actual values via .env or the shell, never commit them.
[env]
OPENAI_BASE_URL = "$LITELLM_BASE_URL"
OPENAI_API_KEY  = "$LITELLM_API_KEY"
AR_MODEL        = "${AR_MODEL:-local/qwen3-8b}"
