# Copy to autoresearch/.env and fill in. .env is gitignored.

# LiteLLM endpoint. Either:
#   (a) port-forward from the cluster:
#       kubectl port-forward -n apps svc/litellm 4000:4000
#       LITELLM_BASE_URL=http://localhost:4000
#   (b) cloudflared tunnel hostname (if exposed):
#       LITELLM_BASE_URL=https://litellm.<your-tunnel-host>
LITELLM_BASE_URL=http://localhost:4000

# LiteLLM master key (litellm-secrets.yaml in nixlab, sops-decrypted).
# Required.
LITELLM_API_KEY=sk-...

# Model the agents use. Routes via LiteLLM's model_list:
#   local/qwen3-8b      → vllm-hermes (Qwen3-8B-AWQ on seir)
#   deepseek-r1-14b     → vllm-deepseek
#   claude-sonnet-4-6   → cloud fallback via OpenRouter
AR_MODEL=local/qwen3-8b
